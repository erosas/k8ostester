#!/usr/bin/env bash
# k8ost without installing anything: runs the tool image with your kubeconfig
# and the current directory mounted. The dashboard/TUI works (TTY allocated);
# results/ land in the CWD as usual.
#
#   docker build -t k8ostester:local k8ostester-core     # once
#   ./k8ost-docker env check
#   ./k8ost-docker run experiments/postgres-cnpg/03-cnpg-ha-3node
#   K8OST_TOOL_IMAGE=my-registry/k8ostester:0.1 ./k8ost-docker session --attach prod-db
set -euo pipefail

IMAGE="${K8OST_TOOL_IMAGE:-k8ostester:local}"
KUBECONFIG_SRC="${KUBECONFIG:-$HOME/.kube/config}"

if [ ! -f "$KUBECONFIG_SRC" ]; then
    echo "k8ost-docker: no kubeconfig at $KUBECONFIG_SRC (set KUBECONFIG)" >&2
    exit 1
fi

# docker-desktop / kind kubeconfigs point at 127.0.0.1 — inside the container
# that is the container itself. Reroute to the host gateway alias (port
# preserved) and pin tls-server-name to localhost, which IS in the API
# server's cert SANs — TLS keeps verifying, no insecure flags.
tmp_config="$(mktemp)"
trap 'rm -f "$tmp_config"' EXIT
awk '
  /server: https:\/\/(127\.0\.0\.1|localhost):/ {
    indent = $0; sub(/[^ ].*/, "", indent)
    sub(/https:\/\/(127\.0\.0\.1|localhost):/, "https://kubernetes.docker.internal:")
    print
    print indent "tls-server-name: localhost"
    next
  }
  { print }
' "$KUBECONFIG_SRC" > "$tmp_config"

tty_flags="-i"
if [ -t 0 ] && [ -t 1 ]; then
    tty_flags="-it"
fi

exec docker run --rm $tty_flags \
    --add-host kubernetes.docker.internal:host-gateway \
    -v "$tmp_config:/kube/config:ro" \
    -e KUBECONFIG=/kube/config \
    -v "$PWD:/work" -w /work \
    -e K8OST_LOADGEN_IMAGE \
    "$IMAGE" "$@"
