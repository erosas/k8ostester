{
  "type": "timeseries",
  "title": "WAL throughput",
  "datasource": {"type": "prometheus", "uid": "${datasource}"},
  "targets": [
    {"expr": "sum(rate(cnpg_collector_wal_bytes{__LABEL__=~\"__CLUSTER__-[0-9]+\"}[5m]))", "legendFormat": "WAL bytes/s", "refId": "A"}
  ],
  "fieldConfig": {
    "defaults": {"unit": "Bps", "custom": {"drawStyle": "line", "fillOpacity": 14}, "color": {"mode": "palette-classic"}},
    "overrides": []
  }
}
